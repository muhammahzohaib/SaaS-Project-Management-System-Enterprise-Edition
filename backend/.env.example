# Server
NODE_ENV=development
PORT=5000
API_VERSION=v1

# MongoDB - Use connection string, never commit real URI
MONGODB_URI=mongodb://localhost:27017/saas_pm

# JWT - Security: Use strong random secrets in production (min 32 chars)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_COOKIE_EXPIRES=7

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS - Restrict origins in production
CORS_ORIGIN=http://localhost:3000

# Email (Nodemailer)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@saaspm.com

# Frontend URL (for emails/links)
FRONTEND_URL=http://localhost:3000
